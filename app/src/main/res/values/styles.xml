<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Text styles -->
    <style name="TextTitle">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="TextHeadline">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="TextBody">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Input style -->
    <style name="InputField">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:padding">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:layout_height">@dimen/control_height</item>
    </style>

    <!-- Button style -->
    <style name="ButtonPrimary">
        <item name="android:background">@drawable/bg_button_green</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_height">@dimen/control_height</item>
    </style>

</resources>
